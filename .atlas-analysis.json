  "keyFeatures": [
    "Real-time audio visualization using Web Audio API",
    "Audio recording with MediaRecorder API",
    "Playback controls with timeline navigation",
    "Fully customizable visual appearance",
    "TypeScript support with complete type definitions",
    "Responsive design for mobile and desktop",
    "Preloaded audio blob support",
    "Lifecycle callbacks for recording and playback events"
  ],
  "publicApiSurface": [
    "useVoiceVisualizer - Main React hook for audio recording control",
    "VoiceVisualizer - React component for audio visualization",
    "Controls - TypeScript interface for hook return values",
    "useVoiceVisualizerParams - TypeScript interface for hook parameters",
    "startRecording() - Start audio recording",
    "stopRecording() - Stop audio recording",
    "togglePauseResume() - Toggle pause/resume state",
    "startAudioPlayback() - Start audio playback",
    "stopAudioPlayback() - Stop audio playback",
    "clearCanvas() - Clear visualization canvas",
    "saveAudioFile() - Download recorded audio",
    "setPreloadedAudioBlob() - Load external audio blob",
    "recordedBlob - Recorded audio as Blob",
    "bufferFromRecordedBlob - Audio buffer for processing",
    "audioData - Real-time audio data for visualization",
    "isRecordingInProgress - Recording state flag",
    "isPausedRecording - Paused recording state flag",
    "duration - Recorded audio duration",
    "currentAudioTime - Current playback time",
    "error - Error object if error occurred"
  ]
}
